{"ast":null,"code":"import{io}from'socket.io-client';const getServerUrl=()=>{if(window.location.hostname.includes('app.github.dev')){return window.location.origin.replace('-3000.','-3001.');}return'http://localhost:3001';};let socket=null;export function getSocket(){if(!socket){socket=io(getServerUrl(),{reconnection:true,reconnectionDelay:1000,reconnectionAttempts:5,withCredentials:false});}return socket;}export function disconnectSocket(){if(socket){socket.disconnect();socket=null;}}","map":{"version":3,"names":["io","getServerUrl","window","location","hostname","includes","origin","replace","socket","getSocket","reconnection","reconnectionDelay","reconnectionAttempts","withCredentials","disconnectSocket","disconnect"],"sources":["/workspaces/cardgames/client/src/socket.js"],"sourcesContent":["import { io } from 'socket.io-client';\n\nconst getServerUrl = () => {\n  if (window.location.hostname.includes('app.github.dev')) {\n    return window.location.origin.replace('-3000.', '-3001.');\n  }\n  return 'http://localhost:3001';\n};\n\nlet socket = null;\n\nexport function getSocket() {\n  if (!socket) {\n    socket = io(getServerUrl(), {\n      reconnection: true,\n      reconnectionDelay: 1000,\n      reconnectionAttempts: 5,\n      withCredentials: false\n    });\n  }\n  return socket;\n}\n\nexport function disconnectSocket() {\n  if (socket) {\n    socket.disconnect();\n    socket = null;\n  }\n}\n"],"mappings":"AAAA,OAASA,EAAE,KAAQ,kBAAkB,CAErC,KAAM,CAAAC,YAAY,CAAGA,CAAA,GAAM,CACzB,GAAIC,MAAM,CAACC,QAAQ,CAACC,QAAQ,CAACC,QAAQ,CAAC,gBAAgB,CAAC,CAAE,CACvD,MAAO,CAAAH,MAAM,CAACC,QAAQ,CAACG,MAAM,CAACC,OAAO,CAAC,QAAQ,CAAE,QAAQ,CAAC,CAC3D,CACA,MAAO,uBAAuB,CAChC,CAAC,CAED,GAAI,CAAAC,MAAM,CAAG,IAAI,CAEjB,MAAO,SAAS,CAAAC,SAASA,CAAA,CAAG,CAC1B,GAAI,CAACD,MAAM,CAAE,CACXA,MAAM,CAAGR,EAAE,CAACC,YAAY,CAAC,CAAC,CAAE,CAC1BS,YAAY,CAAE,IAAI,CAClBC,iBAAiB,CAAE,IAAI,CACvBC,oBAAoB,CAAE,CAAC,CACvBC,eAAe,CAAE,KACnB,CAAC,CAAC,CACJ,CACA,MAAO,CAAAL,MAAM,CACf,CAEA,MAAO,SAAS,CAAAM,gBAAgBA,CAA